# =============================================================================
# LevelSweepAgent — environment variables (EXAMPLE)
# Copy to `.env` (which is gitignored) and fill in real values for local dev.
# Production secrets live in Azure Key Vault per architecture-spec §15.
# =============================================================================

# -- Phase A bootstrap tenant -------------------------------------------------
TENANT_ID=OWNER

# -- Alpaca (single-provider: market data + broker; per ADR-0004) -------------
# Phase A: owner keys; Phase B: per-user OAuth. Algo Trader Plus tier required
# for real-time SIP stocks WS + options chain REST.
ALPACA_API_KEY=replace-me
ALPACA_SECRET_KEY=replace-me
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_WS_BASE_URL=wss://stream.data.alpaca.markets
ALPACA_FEED=sip

# -- Anthropic (AI agents) ----------------------------------------------------
ANTHROPIC_API_KEY=replace-me

# -- Auth0 (IDP) --------------------------------------------------------------
AUTH0_ISSUER=https://YOUR-TENANT.auth0.com/
AUTH0_AUDIENCE=https://api.levelsweep.local
AUTH0_CLIENT_ID=replace-me
AUTH0_CLIENT_SECRET=replace-me

# -- Trading Economics (news blackout calendar) -------------------------------
TRADING_ECONOMICS_API_KEY=replace-me

# -- Notifications ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
EMAIL_FROM=

# -- Local Kafka --------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# -- Local MS SQL -------------------------------------------------------------
MSSQL_URL=jdbc:sqlserver://localhost:1433;databaseName=level_sweep;encrypt=false
MSSQL_USER=sa
MSSQL_PASSWORD=LevelSweep!2026
MSSQL_SA_PASSWORD=LevelSweep!2026

# -- Local Mongo --------------------------------------------------------------
MONGO_URL=mongodb://localhost:27017
MONGO_DB=level_sweep
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=LevelSweep!2026

# -- OpenTelemetry collector (App Insights / Jaeger / Tempo) ------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# -- Azure (Phase 0 placeholder; populated when AKS / Key Vault are stood up) -
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_KEYVAULT_URI=
