<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
      Structured JSON logs with mandatory MDC keys: tenant_id, trace_id.
      Per architecture-spec §18.3 and the multi-tenant-readiness skill.
    -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>tenant_id</includeMdcKeyName>
            <includeMdcKeyName>trace_id</includeMdcKeyName>
            <includeMdcKeyName>notification_id</includeMdcKeyName>
            <customFields>{"service":"notification-service"}</customFields>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="JSON_CONSOLE"/>
    </root>

    <logger name="com.levelsweep" level="INFO"/>
</configuration>
