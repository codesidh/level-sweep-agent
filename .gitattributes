# Default to LF line endings for all text files; Windows working trees use
# CRLF on disk but git stores LF. Prevents Spotless-on-main gate failures
# when Windows-authored PRs flip line endings under the agent's feet.
* text=auto eol=lf

# Shell scripts must be LF (gradlew + scripts).
*.sh   text eol=lf
gradlew text eol=lf

# Windows-only files keep CRLF.
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary blobs (no text conversion).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.jar  binary

# LFS for big media (existing rules).
docs/idea/*.MOV filter=lfs diff=lfs merge=lfs -text
docs/idea/*.mov filter=lfs diff=lfs merge=lfs -text
docs/idea/*.MP4 filter=lfs diff=lfs merge=lfs -text
docs/idea/*.mp4 filter=lfs diff=lfs merge=lfs -text
