root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{java,kt,kts}]
indent_size = 4
max_line_length = 120

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{xml,html,sql}]
indent_size = 2

[*.{md,markdown}]
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.tf,*.tfvars]
indent_size = 2

[*.{bat,cmd}]
end_of_line = crlf
