root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.java]
indent_size = 4
max_line_length = 120

[*.{kt,kts}]
indent_size = 4
# Gradle DSL frequently has long lines for plugin IDs and dependency coords;
# 140 is the Kotlin community default and matches ktlint's recommendation.
max_line_length = 140
# Trailing commas are noisy on multi-line function calls in Gradle DSL files
# (logger.lifecycle, listOf, addAll); disable rather than enforce. We don't
# rely on diff cleanliness for these files.
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{xml,html,sql}]
indent_size = 2

[*.{md,markdown}]
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.tf,*.tfvars]
indent_size = 2

[*.{bat,cmd}]
end_of_line = crlf
